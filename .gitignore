# =========================
# Python cache
# =========================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
ENV/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# IDE / editor files
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# Streamlit secrets
# Keep config.toml, ignore secrets.toml
# =========================
.streamlit/secrets.toml

# =========================
# Environment variables
# =========================
.env
.env.*
!.env.example

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =========================
# Logs
# =========================
*.log
logs/

# =========================
# Temporary files
# =========================
tmp/
temp/
outputs/
uploads/

# =========================
# Model artifacts
# =========================
models/*.joblib
models/*.pkl
models/*.h5
models/*.pt
models/*.pth
models/*.onnx

# =========================
# Large/private/raw data
# =========================
data/raw/
data/private/
data/*.xlsx
data/*.xls

# Keep benchmark CSV files
!data/*.csv

# =========================
# Build/package artifacts
# =========================
build/
dist/
*.egg-info/

# =========================
# Local archives
# =========================
*.zip
*.tar
*.tar.gz
*.rar
