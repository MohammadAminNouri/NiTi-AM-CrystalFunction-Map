# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE/editor junk
.vscode/
.idea/
*.swp
*.swo

# Streamlit secrets
.streamlit/secrets.toml

# Local environment variables
.env
.env.*
!.env.example

# Jupyter checkpoints
.ipynb_checkpoints/

# Logs
*.log
logs/

# Model artifacts / heavy local outputs
models/*.joblib
models/*.pkl
models/*.h5
models/*.pt
models/*.pth
models/*.onnx

# Temporary outputs
outputs/
tmp/
temp/

# Raw local data that should not be committed
data/raw/
data/private/
data/*.xlsx
data/*.xls

# Keep important CSV benchmark data
!data/*.csv

# Uploaded user files
uploads/

# Build artifacts
build/
dist/
*.egg-info/
